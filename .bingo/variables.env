# Auto generated binary variables helper managed by https://github.com/bwplotka/bingo v0.9. DO NOT EDIT.
# All tools are designed to be build inside $GOBIN.
# Those variables will work only until 'bingo get' was invoked, or if tools were installed via Makefile's Variables.mk.
GOBIN=${GOBIN:=$(go env GOBIN)}

if [ -z "$GOBIN" ]; then
	GOBIN="$(go env GOPATH)/bin"
fi

# _BINGO_DIR is the directory that contains this file (and the .mod files).
_BINGO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# _bingo_ver extracts the pinned version from a bingo .mod file so that the
# binary name always matches the declared dependency without requiring edits to
# this file on every version bump.
# Usage: _bingo_ver <tool-name>  e.g. _bingo_ver golangci-lint
_bingo_ver() {
	local ver
	ver="$(grep '^require' "${_BINGO_DIR}/$1.mod" 2>/dev/null | awk '{print $3}')"
	if [ -z "$ver" ]; then
		printf 'error: _bingo_ver: cannot extract version from %s/%s.mod\n' "${_BINGO_DIR}" "$1" >&2
		return 1
	fi
	printf '%s' "$ver"
}


BINGO="${GOBIN}/bingo-$(_bingo_ver bingo)"

BUF="${GOBIN}/buf-$(_bingo_ver buf)"

COPYRIGHT="${GOBIN}/copyright-$(_bingo_ver copyright)"

GOIMPORTS="${GOBIN}/goimports-$(_bingo_ver goimports)"

GOLANGCI_LINT="${GOBIN}/golangci-lint-$(_bingo_ver golangci-lint)"

MDOX="${GOBIN}/mdox-$(_bingo_ver mdox)"

MISSPELL="${GOBIN}/misspell-$(_bingo_ver misspell)"

PROTOC_GEN_GO_GRPC="${GOBIN}/protoc-gen-go-grpc-$(_bingo_ver protoc-gen-go-grpc)"

PROTOC_GEN_GO="${GOBIN}/protoc-gen-go-$(_bingo_ver protoc-gen-go)"

